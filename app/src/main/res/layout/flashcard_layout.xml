<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="1dp"
    android:layout_marginBottom="3dp"
    android:id="@+id/flashcard"
    android:background="@drawable/flashcard_background">
    <TextView
        android:id="@+id/word_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/border"
        android:textSize="16sp"/>

    <View
        android:id="@+id/border"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/darker_gray"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/word_item"
        app:layout_constraintWidth_percent=".95" />
    <TextView
        android:id="@+id/word_item_translations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/border"
        app:layout_constraintBottom_toTopOf="@id/border2"/>
    <View
        android:id="@+id/border2"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/dotted_line"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/word_item_translations"
        app:layout_constraintWidth_percent=".95"
        />
    <TextView
        android:id="@+id/word_item_examples"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/border2"
        app:layout_constraintBottom_toTopOf="@id/border3"/>
    <View
        android:id="@+id/border3"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/dotted_line"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/word_item_examples"
        app:layout_constraintWidth_percent=".95"
        />
    <TextView
        android:id="@+id/word_item_direct_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/border3"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Button
        android:id="@+id/close_button"
        android:text="X"
        android:textSize="10sp"
        android:textColor="@color/white"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="@string/delete_this_card"
        android:background="@drawable/close_button"/>

</androidx.constraintlayout.widget.ConstraintLayout>

